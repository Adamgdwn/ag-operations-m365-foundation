        { "title": "Due / Overdue Actions", "fields": ["LinkTitle", "ActionType", "ActionStatus", "Priority", "DueDate", "OrganizationLookup", "EngagementLookup", "BlocksDecision", "BlocksGoLive", "NextAction"], "query": "<Where><And><Leq><FieldRef Name='DueDate' /><Value Type='DateTime'><Today /></Value></Leq><And><Neq><FieldRef Name='ActionStatus' /><Value Type='Choice'>Complete</Value></Neq><Neq><FieldRef Name='ActionStatus' /><Value Type='Choice'>Cancelled</Value></Neq></And></And></Where><OrderBy><FieldRef Name='DueDate' Ascending='TRUE' /><FieldRef Name='Priority' Ascending='FALSE' /></OrderBy>", "rowLimit": 100 },
        { "title": "Decision / Go-Live Blockers", "fields": ["LinkTitle", "ActionType", "ActionStatus", "Priority", "DueDate", "OrganizationLookup", "EngagementLookup", "BlocksDecision", "BlocksGoLive", "NextAction"], "query": "<Where><And><Or><Eq><FieldRef Name='BlocksDecision' /><Value Type='Boolean'>1</Value></Eq><Eq><FieldRef Name='BlocksGoLive' /><Value Type='Boolean'>1</Value></Eq></Or><Neq><FieldRef Name='ActionStatus' /><Value Type='Choice'>Complete</Value></Neq></And></Where><OrderBy><FieldRef Name='DueDate' Ascending='TRUE' /></OrderBy>", "rowLimit": 100 },
