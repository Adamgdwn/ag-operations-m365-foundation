{
  "version": "2026-06-20-crm-recovery-split",
  "purpose": "Active source of truth for the CRM SharePoint structure: site, lists, fields, views, and content-type expectations. Split out of config/M365_STAGE_8C_RELATIONSHIP_CRM_OPERATOR_WORKFLOW.json (kept as provenance). The intake form contract lives in crm.intake.json; the operator navigation/routing lives in crm.navigation.json. This file does not redefine those.",
  "derivedFrom": [
    "config/M365_STAGE_8C_RELATIONSHIP_CRM_OPERATOR_WORKFLOW.json",
    "docs/CRM_DATA_MODEL.md",
    "docs/CRM_ACCEPTANCE_TESTS.md"
  ],
  "approvalPhrase": "apply-gail-crm-recovery",
  "safetyLimits": [
    "No permission changes",
    "No guest invitations",
    "No external sharing changes",
    "No app grants or consent changes",
    "No public Forms links",
    "No mail sends",
    "No item or list deletions",
    "No unattended automation",
    "No Dynamics or Dataverse provisioning"
  ],
  "site": {
    "title": "Guided AI Labs",
    "url": "https://agoperationsltd.sharepoint.com/sites/GuidedAILabs",
    "pages": {
      "operationsCockpit": "SitePages/Guided-AI-Labs-Operations-Cockpit.aspx",
      "crmCommandCenter": "SitePages/Relationship-CRM-Command-Center.aspx"
    }
  },
  "contentTypeExpectations": {
    "note": "Key Stage 8C failure: hidden technical fields passed verification with ShowInNewForm/ShowInEditForm = DefaultTrue. The recovery requires that every field in crm.intake.json.blockedFieldNames has ShowInNewForm=false AND ShowInEditForm=false on CRM - New Signals, regardless of whether content types are enabled.",
    "hiddenFieldFormFlags": { "ShowInNewForm": false, "ShowInEditForm": false }
  },
  "lists": [
    {
      "title": "CRM - New Signals",
      "role": "primary-intake",
      "description": "Clean SharePoint-native business-development intake for new opportunities, referrals, support signals, discovery starts, and pasted email/context. This is the daily CRM capture surface. Allowed to use the native SharePoint form because it carries only clean business fields.",
      "quickLaunch": false,
      "columns": [
        { "displayName": "SignalStatus", "internalName": "SignalStatus", "type": "Choice", "choices": ["New", "Triage", "Waiting on Adam", "Follow-up scheduled", "Qualified", "Nurture", "Disqualified", "Converted", "Closed"], "default": "New", "indexed": true },
        { "displayName": "SignalType", "internalName": "SignalType", "type": "Choice", "choices": ["Referral", "Website", "Direct outreach", "Existing client", "Partner", "Support signal", "Internal idea", "Email", "Other"], "default": "Referral", "indexed": true },
        { "displayName": "Priority", "internalName": "Priority", "type": "Choice", "choices": ["Low", "Normal", "High", "Urgent"], "default": "Normal", "indexed": true },
        { "displayName": "PersonName", "internalName": "PersonName", "type": "Text" },
        { "displayName": "PersonEmail", "internalName": "PersonEmail", "type": "Text" },
        { "displayName": "OrganizationName", "internalName": "OrganizationName", "type": "Text", "indexed": true },
        { "displayName": "NeedSummary", "internalName": "NeedSummary", "type": "Note" },
        { "displayName": "SourceText", "internalName": "SourceText", "type": "Note" },
        { "displayName": "NextAction", "internalName": "NextAction", "type": "Note" },
        { "displayName": "FollowUpDueDate", "internalName": "FollowUpDueDate", "type": "DateTime", "indexed": true },
        { "displayName": "RelatedLink", "internalName": "RelatedLink", "type": "URL" },
        { "displayName": "Owner", "internalName": "ItemOwner", "type": "User" }
      ],
      "lookupFields": [],
      "views": [
        { "title": "New Signal Queue", "fields": ["LinkTitle", "SignalStatus", "SignalType", "Priority", "PersonName", "PersonEmail", "OrganizationName", "FollowUpDueDate", "NextAction"], "query": "<Where><Or><Eq><FieldRef Name='SignalStatus' /><Value Type='Choice'>New</Value></Eq><Eq><FieldRef Name='SignalStatus' /><Value Type='Choice'>Triage</Value></Eq></Or></Where><OrderBy><FieldRef Name='Priority' Ascending='FALSE' /><FieldRef Name='Created' Ascending='FALSE' /></OrderBy>", "rowLimit": 100, "default": true },
        { "title": "Signals Needing Follow-up", "fields": ["LinkTitle", "SignalStatus", "SignalType", "Priority", "OrganizationName", "PersonName", "FollowUpDueDate", "NextAction"], "query": "<Where><And><Leq><FieldRef Name='FollowUpDueDate' /><Value Type='DateTime'><Today /></Value></Leq><Neq><FieldRef Name='SignalStatus' /><Value Type='Choice'>Closed</Value></Neq></And></Where><OrderBy><FieldRef Name='FollowUpDueDate' Ascending='TRUE' /></OrderBy>", "rowLimit": 100 },
        { "title": "Converted / Closed Signals", "fields": ["LinkTitle", "SignalStatus", "SignalType", "OrganizationName", "PersonName", "Modified"], "query": "<Where><Or><Eq><FieldRef Name='SignalStatus' /><Value Type='Choice'>Converted</Value></Eq><Eq><FieldRef Name='SignalStatus' /><Value Type='Choice'>Closed</Value></Eq></Or></Where><OrderBy><FieldRef Name='Modified' Ascending='FALSE' /></OrderBy>", "rowLimit": 100 }
      ]
    },
