        { "displayName": "CompletedDate", "internalName": "CompletedDate", "type": "DateTime" },
        { "displayName": "NextAction", "internalName": "NextAction", "type": "Note" },
        { "displayName": "Outcome", "internalName": "Outcome", "type": "Note" },
        { "displayName": "BlocksDecision", "internalName": "BlocksDecision", "type": "Boolean", "default": "0", "indexed": true },
        { "displayName": "BlocksGoLive", "internalName": "BlocksGoLive", "type": "Boolean", "default": "0", "indexed": true },
        { "displayName": "SourceSystem", "internalName": "SourceSystem", "type": "Choice", "choices": ["Manual", "Intake Register", "CRM Touchpoint", "Meeting", "Checklist", "Agent Suggested", "Other"], "default": "Manual" }
      ],
      "lookupFields": [
        { "displayName": "Organization", "internalName": "OrganizationLookup", "targetList": "CRM - Organizations", "targetField": "Title", "indexed": true },
        { "displayName": "Engagement", "internalName": "EngagementLookup", "targetList": "CRM - Engagements", "targetField": "Title", "indexed": true },
        { "displayName": "Contact", "internalName": "ContactLookup", "targetList": "CRM - Contacts", "targetField": "Title", "indexed": true },
        { "displayName": "Touchpoint", "internalName": "TouchpointLookup", "targetList": "CRM - Touchpoints", "targetField": "Title" }
