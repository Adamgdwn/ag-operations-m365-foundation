  "lists": [
    {
      "title": "Client Workspace Register",
      "description": "Client and partner workspace model, tenant ownership, status, access posture, and handoff state.",
      "quickLaunch": false,
      "columns": [
        { "displayName": "Workspace Model", "internalName": "WorkspaceModel", "type": "Choice", "choices": ["Client tenant first", "GAL-hosted light workspace", "Hybrid delivery workspace", "Internal partner workspace"], "default": "Client tenant first" },
        { "displayName": "Ownership Posture", "internalName": "OwnershipPosture", "type": "Choice", "choices": ["Client owns records", "GAL owns operating records", "Split by sensitivity", "Pending decision"], "default": "Pending decision" },
        { "displayName": "Status", "internalName": "WorkspaceStatus", "type": "Choice", "choices": ["Proposed", "Discovery", "Build", "Active", "Handoff", "Closed"], "default": "Proposed" },
        { "displayName": "Primary Owner", "internalName": "PrimaryOwner", "type": "User" },
        { "displayName": "Tenant Of Record", "internalName": "TenantOfRecord", "type": "Text" },
        { "displayName": "Access Posture", "internalName": "AccessPosture", "type": "Choice", "choices": ["Internal only", "Named guests approved", "Client tenant", "Pending decision"], "default": "Pending decision" },
        { "displayName": "External Access Approved", "internalName": "ExternalAccessApproved", "type": "Choice", "choices": ["No", "Pending", "Yes"], "default": "No" },
        { "displayName": "Handoff State", "internalName": "HandoffState", "type": "Choice", "choices": ["Not started", "Drafting", "Ready for review", "Issued", "Accepted", "Not applicable"], "default": "Not started" },
        { "displayName": "Review Date", "internalName": "ReviewDate", "type": "DateTime" },
        { "displayName": "Workspace Map URL", "internalName": "WorkspaceMapUrl", "type": "URL" },
        { "displayName": "Notes", "internalName": "Notes", "type": "Note" }
      ],
      "views": [
        { "title": "Active Workspaces", "fields": ["LinkTitle", "WorkspaceModel", "OwnershipPosture", "WorkspaceStatus", "PrimaryOwner", "AccessPosture", "HandoffState", "ReviewDate"], "default": true },
        { "title": "Handoff Needed", "fields": ["LinkTitle", "WorkspaceStatus", "HandoffState", "PrimaryOwner", "ReviewDate", "WorkspaceMapUrl"] },
        { "title": "Access Review", "fields": ["LinkTitle", "AccessPosture", "ExternalAccessApproved", "PrimaryOwner", "ReviewDate", "Notes"] }
      ]
    },
    {
      "title": "Handoff Packet Register",
      "description": "Workspace handoff owner, links, training state, closeout/export path, and next review date.",
      "quickLaunch": false,
      "columns": [
        { "displayName": "Client Or Workspace", "internalName": "ClientOrWorkspace", "type": "Text" },
        { "displayName": "Packet Status", "internalName": "PacketStatus", "type": "Choice", "choices": ["Draft", "Ready for review", "Issued", "Accepted", "Archived"], "default": "Draft" },
        { "displayName": "Handoff Owner", "internalName": "HandoffOwner", "type": "User" },
        { "displayName": "Training State", "internalName": "TrainingState", "type": "Choice", "choices": ["Not started", "Scheduled", "Delivered", "Accepted", "Not applicable"], "default": "Not started" },
        { "displayName": "Workspace Map URL", "internalName": "WorkspaceMapUrl", "type": "URL" },
        { "displayName": "Packet Library URL", "internalName": "PacketLibraryUrl", "type": "URL" },
        { "displayName": "Closeout Export Path", "internalName": "CloseoutExportPath", "type": "Note" },
        { "displayName": "Next Review Date", "internalName": "NextReviewDate", "type": "DateTime" },
        { "displayName": "Notes", "internalName": "Notes", "type": "Note" }
      ],
      "views": [
        { "title": "Active Handoffs", "fields": ["LinkTitle", "ClientOrWorkspace", "PacketStatus", "HandoffOwner", "TrainingState", "NextReviewDate"], "default": true },
        { "title": "Ready For Review", "fields": ["LinkTitle", "ClientOrWorkspace", "PacketStatus", "HandoffOwner", "WorkspaceMapUrl", "PacketLibraryUrl"] },
        { "title": "Archived Packets", "fields": ["LinkTitle", "ClientOrWorkspace", "PacketStatus", "NextReviewDate", "Notes"] }
      ]
    },
    {
      "title": "Tool Permission Review",
      "description": "App grants, agent scopes, risky permissions, workflow owner, and review cadence.",
      "quickLaunch": false,
      "columns": [
        { "displayName": "Permission Area", "internalName": "PermissionArea", "type": "Choice", "choices": ["Microsoft Graph", "SharePoint", "Teams", "Planner", "Forms", "Power Automate", "Local tool", "Other"], "default": "Microsoft Graph" },
        { "displayName": "Current Grant", "internalName": "CurrentGrant", "type": "Text" },
        { "displayName": "Risk Level", "internalName": "RiskLevel", "type": "Choice", "choices": ["Low", "Medium", "High", "Retire"], "default": "Medium" },
        { "displayName": "Owner", "internalName": "Owner", "type": "User" },
        { "displayName": "Review Status", "internalName": "ReviewStatus", "type": "Choice", "choices": ["Needs review", "Approved", "Reduce scope", "Retire", "Blocked"], "default": "Needs review" },
        { "displayName": "Review Date", "internalName": "ReviewDate", "type": "DateTime" },
        { "displayName": "Decision Register Link", "internalName": "DecisionRegisterLink", "type": "URL" },
        { "displayName": "Notes", "internalName": "Notes", "type": "Note" }
      ],
      "views": [
        { "title": "Needs Review", "fields": ["LinkTitle", "PermissionArea", "CurrentGrant", "RiskLevel", "Owner", "ReviewStatus", "ReviewDate"], "default": true },
        { "title": "High Risk", "fields": ["LinkTitle", "PermissionArea", "CurrentGrant", "RiskLevel", "Owner", "ReviewStatus", "DecisionRegisterLink"] }
      ]
    },
    {
      "title": "Automation Backlog",
      "description": "Proposed automations before build, use, or client-facing approval.",
      "quickLaunch": false,
      "columns": [
        { "displayName": "Workflow Area", "internalName": "WorkflowArea", "type": "Choice", "choices": ["Intake", "Delivery", "Governance", "Handoff", "Reporting", "Client-facing", "Internal operations"], "default": "Internal operations" },
        { "displayName": "Proposed Value", "internalName": "ProposedValue", "type": "Note" },
        { "displayName": "Risk Level", "internalName": "RiskLevel", "type": "Choice", "choices": ["Low", "Medium", "High"], "default": "Medium" },
        { "displayName": "Approval Status", "internalName": "ApprovalStatus", "type": "Choice", "choices": ["Idea", "Needs approval", "Approved to build", "Approved to run", "Paused", "Retired"], "default": "Idea" },
        { "displayName": "Owner", "internalName": "Owner", "type": "User" },
        { "displayName": "Source Surface", "internalName": "SourceSurface", "type": "Text" },
        { "displayName": "Target System", "internalName": "TargetSystem", "type": "Text" },
        { "displayName": "Human Approval Required", "internalName": "HumanApprovalRequired", "type": "Boolean" },
        { "displayName": "Review Date", "internalName": "ReviewDate", "type": "DateTime" },
        { "displayName": "Notes", "internalName": "Notes", "type": "Note" }
      ],
      "views": [
        { "title": "Backlog", "fields": ["LinkTitle", "WorkflowArea", "RiskLevel", "ApprovalStatus", "Owner", "HumanApprovalRequired", "ReviewDate"], "default": true },
        { "title": "Needs Approval", "fields": ["LinkTitle", "WorkflowArea", "RiskLevel", "ApprovalStatus", "Owner", "ProposedValue"] }
      ]
    },
    {
      "title": "Exception Register",
      "description": "Approved deviations with owner, expiry, review date, and closure path.",
      "quickLaunch": false,
      "columns": [
        { "displayName": "Exception Area", "internalName": "ExceptionArea", "type": "Choice", "choices": ["Access", "Sharing", "App grant", "Client records", "Automation", "Retention", "Other"], "default": "Other" },
        { "displayName": "Status", "internalName": "ExceptionStatus", "type": "Choice", "choices": ["Proposed", "Approved", "Expiring", "Closed", "Rejected"], "default": "Proposed" },
        { "displayName": "Approved By", "internalName": "ApprovedBy", "type": "User" },
        { "displayName": "Expiry Date", "internalName": "ExpiryDate", "type": "DateTime" },
        { "displayName": "Review Date", "internalName": "ReviewDate", "type": "DateTime" },
        { "displayName": "Decision Register Link", "internalName": "DecisionRegisterLink", "type": "URL" },
        { "displayName": "Closure Path", "internalName": "ClosurePath", "type": "Note" },
        { "displayName": "Notes", "internalName": "Notes", "type": "Note" }
      ],
      "views": [
        { "title": "Open Exceptions", "fields": ["LinkTitle", "ExceptionArea", "ExceptionStatus", "ApprovedBy", "ExpiryDate", "ReviewDate"], "default": true },
        { "title": "Expiring Soon", "fields": ["LinkTitle", "ExceptionArea", "ExceptionStatus", "ExpiryDate", "ReviewDate", "ClosurePath"] }
      ]
    }
  ],
