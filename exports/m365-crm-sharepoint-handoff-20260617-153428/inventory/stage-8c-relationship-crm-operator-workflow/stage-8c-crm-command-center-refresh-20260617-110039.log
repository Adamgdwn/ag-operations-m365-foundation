>> function Get-ListViewUrl {
    param([string]$ListTitle, [string]$ViewTitle)
    $view = Get-PnPView -List $ListTitle -Identity $ViewTitle -ErrorAction SilentlyContinue
    if ($null -ne $view -and -not [string]::IsNullOrWhiteSpace([string]$view.ServerRelativeUrl)) { return [string]$view.ServerRelativeUrl }
    $list = Get-PnPList -Identity $ListTitle -Includes DefaultViewUrl,RootFolder
    if (-not [string]::IsNullOrWhiteSpace([string]$list.DefaultViewUrl)) { return [string]$list.DefaultViewUrl }
    return [string]$list.RootFolder.ServerRelativeUrl
}
function New-CommandCenterPageHtml {
    param([object]$Config)
    $page = $Config.pages[0]
    $title = ConvertTo-HtmlText ([string]$page.title)
    $role = ConvertTo-HtmlText ([string]$page.role)
    $stagePathHtml = foreach ($stage in $page.stagePath) {
        $label = ConvertTo-HtmlText ([string]$stage.label)
        $description = ConvertTo-HtmlText ([string]$stage.description)
        $url = ConvertTo-HtmlText (Get-ListViewUrl -ListTitle ([string]$stage.list) -ViewTitle ([string]$stage.view))
        $list = ConvertTo-HtmlText ([string]$stage.list)
        $view = ConvertTo-HtmlText ([string]$stage.view)
        '<li><strong><a href="{0}">{1}</a></strong> - {2}<br/><span>{3} / {4}</span></li>' -f $url, $label, $description, $list, $view
    }
    $linkHtml = foreach ($link in $page.directLinks) {
        $label = ConvertTo-HtmlText ([string]$link.label)
        $url = ConvertTo-HtmlText (Get-ListViewUrl -ListTitle ([string]$link.list) -ViewTitle ([string]$link.view))
        $list = ConvertTo-HtmlText ([string]$link.list)
        $view = ConvertTo-HtmlText ([string]$link.view)
        '<li><a href="{0}">{1}</a> - {2} / {3}</li>' -f $url, $label, $list, $view
    }
    $proofHtml = foreach ($step in $Config.workflowProof) { '<li>{0}</li>' -f (ConvertTo-HtmlText ([string]$step)) }
@"
<h2>$title</h2>
<p><strong>Role:</strong> $role</p>
<p>Start here for the daily CRM operating loop: follow the visible stage path first, then use the queue links for actions, meetings, artifacts, and relationship health.</p>
<h3>CRM stage path</h3>
<ol>$($stagePathHtml -join '')</ol>
<h3>Command links</h3>
<ul>$($linkHtml -join '')</ul>
<h3>Operating rhythm</h3>
<ol>$($proofHtml -join '')</ol>
<p><em>Generated from the Stage 8C CRM operator workflow config. This page does not create permissions, guests, sharing, app consent, mail sends, public forms, item deletions, Dynamics, Dataverse, or unattended automation.</em></p>
"@
}
