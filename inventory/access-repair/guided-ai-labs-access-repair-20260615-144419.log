>> try {
    Write-Host "Connecting to $siteUrl" -ForegroundColor Cyan
    Connect-PnPOnline -Url $siteUrl -OSLogin
    $web = Get-PnPWeb -Includes AssociatedOwnerGroup,AssociatedMemberGroup,AssociatedVisitorGroup,Title,Url
    Write-Host "Site: $($web.Title) <$($web.Url)>" -ForegroundColor White
    Write-Host "Owners group: $($web.AssociatedOwnerGroup.Title)" -ForegroundColor White
    Write-Host "Members group: $($web.AssociatedMemberGroup.Title)" -ForegroundColor White
    Write-Host "Ensuring user exists: $userUpn" -ForegroundColor Cyan
    $user = New-PnPUser -LoginName $userUpn
    Write-Host "Resolved user: $($user.Title) <$($user.LoginName)>" -ForegroundColor White
    $ownersGroup = $web.AssociatedOwnerGroup.Title
    $ownerMembersBefore = @(Get-PnPGroupMember -Identity $ownersGroup | Select-Object Title,LoginName,Email)
    $alreadyOwner = @($ownerMembersBefore | Where-Object { $_.Email -eq $userUpn -or $_.LoginName -like "*$userUpn*" }).Count -gt 0
    if (-not $alreadyOwner) {
        Write-Host "Adding $userUpn to site owners group: $ownersGroup" -ForegroundColor Yellow
        Add-PnPGroupMember -Identity $ownersGroup -LoginName $userUpn | Out-Null
    } else {
        Write-Host "$userUpn is already in the site owners group." -ForegroundColor Green
    }
