# Microsoft 365 / Entra environment template
# Copy to a private local file only if needed, for example:
# M365_ENVIRONMENT.local.env
#
# Do not commit or share files containing secrets.

# Tenant
M365_TENANT_NAME="A.G. Operations Ltd"
M365_TENANT_ID="1ca92af5-21ff-42e3-87ae-3bde9c2cc501"
M365_PRIMARY_DOMAIN="agoperations.ca"
M365_ONMICROSOFT_DOMAIN="AGOperationsLtd.onmicrosoft.com"

# Verified domains
M365_DOMAIN_AGOPS="agoperations.ca"
M365_DOMAIN_GUIDED_AI_LABS="guidedailabs.com"
M365_DOMAIN_CHANGE_LEADERSHIP_TOOLS="changeleadershiptools.com"

# Main accounts
M365_ADMIN_ACCOUNT="admin@agoperations.ca"
M365_DAILY_ACCOUNT="adamgoodwin@guidedailabs.com"
M365_FRONT_DOOR_ACCOUNT="contact@guidedailabs.com"
M365_SUPPORT_ACCOUNT="support@changeleadershiptools.com"

# Entra app registration for setup/inventory helper
M365_APP_NAME="AG Operations Agentic Partner"
M365_CLIENT_ID="2d0c6ba1-1ad9-494e-8583-5442f84c4199"
M365_OBJECT_ID="4bcce061-1133-4b95-9ac5-60d09ae846c4"
M365_APPLICATION_ID_URI=""

# OAuth / Microsoft identity platform
M365_AUTHORITY_HOST="https://login.microsoftonline.com"
M365_AUTHORITY_URL="https://login.microsoftonline.com/${M365_TENANT_ID}"
M365_GRAPH_BASE_URL="https://graph.microsoft.com/v1.0"

# Delegated Graph scopes for first inventory pass
# Start read-only. Add write scopes only for specific approved tasks.
M365_GRAPH_SCOPES="User.Read Organization.Read.All Domain.Read.All Directory.Read.All Group.Read.All Sites.Read.All Files.Read.All Team.ReadBasic.All"

# Redirect URI
# Leave blank unless a specific local/web app needs OAuth redirect flow.
M365_REDIRECT_URI=""

# Admin portals
M365_ADMIN_CENTER_URL="https://admin.microsoft.com"
M365_ENTRA_ADMIN_URL="https://entra.microsoft.com"
M365_EXCHANGE_ADMIN_URL="https://admin.exchange.microsoft.com"
M365_SHAREPOINT_ADMIN_URL="https://admin.microsoft.com/sharepoint"
M365_TEAMS_ADMIN_URL="https://admin.teams.microsoft.com"
M365_PURVIEW_URL="https://purview.microsoft.com"
M365_DEFENDER_URL="https://security.microsoft.com"

# Notes
# If a future background service needs unattended access, create a separate app
# registration and store its certificate/secret in a secure vault, not here.
