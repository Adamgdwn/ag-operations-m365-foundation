# Local environment files that may contain secrets — never commit these.
*.local.env
M365_ENVIRONMENT.local.env

# Anything explicitly marked secret/private.
*.secret
*.secret.*
secrets/
.secrets/

# OS / editor noise
Thumbs.db
desktop.ini
.DS_Store
.vscode/

# Auth token caches that some Graph/MSAL flows may write locally
.msal_token_cache*
*.token.json

# Local agentic browser profile (holds authenticated tenant session cookies) — never commit
.local/

# Forms-builder intermediate debug captures (auth/explore screenshots + control dumps).
# Keep the result JSONs and the public-render proofs; drop the throwaway debug noise.
inventory/forms-build/forms-*/
inventory/forms-build/explore/

# Generated graph/index output (graphify) — large derived artifact, not source.
graphify-out/

